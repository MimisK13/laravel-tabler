{
    "name": "mimisk13/laravel-tabler",
    "description": "Laravel Tabler UI",
    "license": "MIT",
    "authors": [
        {
            "name": "Mimis K",
            "email": "mimisk88@gmail.com"
        }
    ],
    "homepage": "https://github.com/mimisk13/laravel-tabler",
    "keywords": ["Laravel", "LaravelTabler"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravolt/avatar": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MimisK13\\LaravelTabler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MimisK13\\LaravelTabler\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "@php vendor/phpunit/phpunit/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MimisK13\\LaravelTabler\\LaravelTablerServiceProvider"
            ],
            "aliases": {
                "LaravelTabler": "MimisK13\\LaravelTabler\\Facades\\LaravelTabler"
            }
        }
    }
}
